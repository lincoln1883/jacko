#!/bin/bash

# Development Environment Setup Script for Jacko
# This script sets up the complete development environment

set -e

echo "🚀 Setting up Jacko development environment..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    echo -e "${GREEN}✅ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

print_error() {
    echo -e "${RED}❌ $1${NC}"
}

# Check if running in Docker
if [ -f /.dockerenv ]; then
    echo "🐳 Running inside Docker container"
    DOCKER_ENV=true
else
    echo "💻 Running on local machine"
    DOCKER_ENV=false
fi

# Function to check if command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Check prerequisites
echo "🔍 Checking prerequisites..."

if ! command_exists git; then
    print_error "Git is not installed"
    exit 1
fi

if ! command_exists ruby; then
    print_error "Ruby is not installed"
    exit 1
fi

if ! command_exists node; then
    print_error "Node.js is not installed"  
    exit 1
fi

if ! command_exists bundle; then
    print_error "Bundler is not installed. Run: gem install bundler"
    exit 1
fi

print_status "All prerequisites are installed"

# Install Ruby dependencies
echo "💎 Installing Ruby dependencies..."
if bundle install; then
    print_status "Ruby dependencies installed"
else
    print_error "Failed to install Ruby dependencies"
    exit 1
fi

# Install Node.js dependencies
echo "📦 Installing Node.js dependencies..."
if npm install; then
    print_status "Node.js dependencies installed"
else
    print_error "Failed to install Node.js dependencies"
    exit 1
fi

# Setup database
echo "🗄️ Setting up database..."

if [ "$DOCKER_ENV" = true ]; then
    # In Docker, wait for database to be ready
    echo "Waiting for database to be ready..."
    until bin/rails runner "ActiveRecord::Base.connection.execute('SELECT 1')" >/dev/null 2>&1; do
        sleep 1
    done
fi

# Check if database exists
if bin/rails runner "ActiveRecord::Base.connection" >/dev/null 2>&1; then
    print_warning "Database already exists, running migrations..."
    bin/rails db:migrate
else
    print_status "Creating database..."
    bin/rails db:create
    bin/rails db:migrate
fi

# Seed database if needed
if bin/rails runner "User.count == 0" 2>/dev/null; then
    echo "🌱 Seeding database with sample data..."
    bin/rails db:seed
    print_status "Database seeded"
else
    print_status "Database already has data"
fi

# Setup Git hooks
echo "🔧 Setting up Git hooks..."
if [ -d ".git" ]; then
    # Create enhanced pre-commit hook with frontend checks
    cat > .git/hooks/pre-commit << 'EOF'
#!/bin/sh

# Enhanced Pre-commit Hook for Jacko
# Runs comprehensive checks for both backend and frontend

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored output
print_step() {
    echo -e "${BLUE}🔍 $1${NC}"
}

print_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

print_error() {
    echo -e "${RED}❌ $1${NC}"
    exit 1
}

print_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

echo -e "${BLUE}🚀 Running pre-commit checks for Jacko...${NC}"
echo ""

# Check if Node.js dependencies are installed
if [ ! -d "node_modules" ]; then
    print_warning "Node.js dependencies not found. Installing..."
    npm install
fi

# ============================================
# BACKEND CHECKS
# ============================================

print_step "Running backend checks..."

# Run RuboCop
print_step "Checking Ruby code style with RuboCop..."
if ! bundle exec rubocop --fail-level error; then
    print_error "RuboCop failed. Fix the style issues and try again."
fi
print_success "RuboCop passed"

# Run RSpec (quick tests only, excluding slow tests)
print_step "Running backend tests (excluding slow tests)..."
if ! bundle exec rspec --tag ~slow --fail-fast; then
    print_error "Backend tests failed. Fix the failing tests and try again."
fi
print_success "Backend tests passed"

# ============================================
# FRONTEND CHECKS
# ============================================

print_step "Running frontend checks..."

# TypeScript type checking
print_step "Checking TypeScript types..."
if ! npm run check; then
    print_error "TypeScript type checking failed. Fix the type errors and try again."
fi
print_success "TypeScript types are valid"

# ESLint linting
print_step "Linting frontend code with ESLint..."
if ! npm run lint; then
    print_error "ESLint failed. Fix the linting issues and try again. Hint: Try 'npm run lint:fix' for auto-fixes."
fi
print_success "Frontend code linting passed"

# Prettier formatting check
print_step "Checking code formatting with Prettier..."
if ! npm run format:check; then
    print_error "Code formatting check failed. Run 'npm run format' to fix formatting issues."
fi
print_success "Code formatting is consistent"

# Frontend tests
print_step "Running frontend tests..."
if ! npm run test; then
    print_error "Frontend tests failed. Fix the failing tests and try again."
fi
print_success "Frontend tests passed"

# ============================================
# FINAL SUCCESS
# ============================================

echo ""
echo -e "${GREEN}🎉 All pre-commit checks passed!${NC}"
echo -e "${GREEN}✨ Your code is ready for commit!${NC}"
echo ""
EOF

    chmod +x .git/hooks/pre-commit
    print_status "Enhanced Git hooks installed (includes frontend checks)"
else
    print_warning "Not a Git repository, skipping Git hooks"
fi

# Create .env.local if it doesn't exist
if [ ! -f ".env.local" ]; then
    echo "📝 Creating .env.local file..."
    cat > .env.local << EOF
# Jacko Development Environment Variables
# Copy this file and customize as needed

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/jacko_development
REDIS_URL=redis://localhost:6379/0

# Rails
RAILS_ENV=development
RAILS_LOG_LEVEL=debug

# Vite Ruby
VITE_RUBY_HOST=0.0.0.0
VITE_RUBY_PORT=5173

# External Services (add your keys)
# STRIPE_SECRET_KEY=sk_test_...
# GOOGLE_MAPS_API_KEY=...
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
EOF
    print_status ".env.local created"
else
    print_status ".env.local already exists"
fi

# Build frontend assets
echo "🏗️ Building frontend assets..."
if npm run build; then
    print_status "Frontend assets built"
else
    print_warning "Failed to build frontend assets (this is okay for first setup)"
fi

# Run initial tests to verify setup
echo "🧪 Running initial tests..."
if bundle exec rspec --format progress | tail -1; then
    print_status "Initial tests passed"
else
    print_warning "Some tests failed (this might be expected for initial setup)"
fi

# Final setup verification
echo "🔍 Verifying setup..."

# Check if Rails can start
if timeout 10s bin/rails runner "puts 'Rails is working!'" >/dev/null 2>&1; then
    print_status "Rails environment is working"
else
    print_error "Rails environment has issues"
    exit 1
fi

echo ""
echo "🎉 Development environment setup complete!"
echo ""
echo "📋 Next steps:"
echo "  1. Start the development server: bin/dev"
echo "  2. Visit http://localhost:3000"
echo "  3. Check the README.md for more information"
echo "  4. Review the MVP task list in docs/MVP_TASK_LIST.md"
echo ""
echo "🔧 Useful commands:"
echo "  bin/dev                    - Start development servers"
echo "  bin/rails console          - Rails console"
echo "  bundle exec rspec          - Run tests"
echo "  npm run lint               - Run frontend linting"
echo "  ./bin/db_backup            - Backup database"
echo ""
echo "Happy coding! 🚀"
