#!/bin/bash

# Database backup script for Jacko Rails application
# Usage: ./bin/db_backup [backup_name]

set -e

# Configuration
CONTAINER_NAME="jacko-db-1"
DB_NAME="jacko_development"
DB_USER="postgres"
BACKUP_DIR="./backups/db"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)

# Create backup directory if it doesn't exist
mkdir -p "$BACKUP_DIR"

# Set backup filename
if [ -z "$1" ]; then
    BACKUP_NAME="jacko_dev_${TIMESTAMP}.sql"
else
    BACKUP_NAME="${1}_${TIMESTAMP}.sql"
fi

BACKUP_PATH="$BACKUP_DIR/$BACKUP_NAME"

echo "🗄️  Creating database backup..."
echo "Database: $DB_NAME"
echo "Backup file: $BACKUP_PATH"

# Check if container is running
if ! docker ps | grep -q "$CONTAINER_NAME"; then
    echo "❌ Error: Database container '$CONTAINER_NAME' is not running"
    echo "Please start your development environment with: docker-compose up -d db"
    exit 1
fi

# Create backup
if docker exec -t "$CONTAINER_NAME" pg_dump -U "$DB_USER" -d "$DB_NAME" --clean --no-owner --no-privileges > "$BACKUP_PATH"; then
    echo "✅ Backup created successfully: $BACKUP_PATH"
    
    # Show backup size
    BACKUP_SIZE=$(ls -lh "$BACKUP_PATH" | awk '{print $5}')
    echo "📊 Backup size: $BACKUP_SIZE"
    
    # List recent backups
    echo "📝 Recent backups:"
    ls -lt "$BACKUP_DIR"/*.sql 2>/dev/null | head -5 || echo "No previous backups found"
else
    echo "❌ Backup failed!"
    rm -f "$BACKUP_PATH" 2>/dev/null
    exit 1
fi
