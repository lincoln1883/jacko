{
  "all": {
    "sourceCodeDir": "app/frontend",
    "watchAdditionalPaths": []
  },
  "development": {
    "autoBuild": true,
    "publicOutputDir": "vite-dev",
    "port": 3036,
    "entrypoints": [
      "entrypoints/application.js",
      "entrypoints/application.css"
    ]
  },
  "test": {
    "autoBuild": true,
    "publicOutputDir": "vite-test",
    "port": 3037,
    "entrypoints": [
      "entrypoints/application.js",
      "entrypoints/application.css"
    ]
  },
  "production": {
    "autoBuild": false,
    "publicOutputDir": "assets",
    "entrypoints": [
      "entrypoints/application.js",
      "entrypoints/application.css",
      "entrypoints/inertia.ts"
    ]
  }
}
